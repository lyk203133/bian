<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>layui</title>
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <link rel="stylesheet" href="/public/lib/layui-v2.6.3/css/layui.css" media="all">
    <link rel="stylesheet" href="/public/css/public.css" media="all">
</head>

<body>
    <div class="layuimini-container">
        <div class="layuimini-main">

            <fieldset class="table-search-fieldset">
                <legend>搜索信息</legend>
                <div style="margin: 10px 10px 10px 10px">
                    <form class="layui-form layui-form-pane" action="">
                        <div class="layui-form-item">
                            <div class="layui-inline">
                                <label class="layui-form-label">關鍵字</label>
                                <div class="layui-input-inline">
                                    <input type="text" name="keyword" autocomplete="off" class="layui-input" value="">
                                    <input type="hidden" name="role" value="1" />
                                </div>
                            </div>

                            <!--div class="layui-inline" id="dvregtime">
                                <label class="layui-form-label">註冊時間</label>
                                <div class="layui-input-inline">
                                    <input type="text" name="begintime" autocomplete="off" id="txtbegintime"
                                        class="layui-input" placeholder="開始日期">
                                </div>
                                <div class="layui-form-mid">-</div>
                                <div class="layui-input-inline">
                                    <input type="text" name="endtime" autocomplete="off" id="txtendtime"
                                        class="layui-input" placeholder="結束日期">
                                </div>
                            </div-->
                            <div class="layui-inline">
                                <button type="submit" class="layui-btn layui-btn-primary" lay-submit
                                    lay-filter="data-search-btn"><i class="layui-icon"></i> 搜 索</button>
                            </div>
                        </div>

                    </form>

                </div>
            </fieldset>

            <script type="text/html" id="toolbarDemo">
            <div class="layui-btn-container">
                <!--button class="layui-btn layui-btn-normal layui-btn-sm data-add-btn" lay-event="add"> 新增 </button-->

            </div>
        </script>

            <table class="layui-hide" id="currentTableId" lay-filter="currentTableFilter"></table>

            <script type="text/html" id="currentTableBar">
            <!--a class="layui-btn layui-btn-normal layui-btn-xs data-count-verify" lay-event="verify">查看</a-->

            <a class="layui-btn layui-btn-normal layui-btn-xs data-count-danger" lay-event="changeBalance">人工充值</a>
            <a class="layui-btn layui-btn-normal layui-btn-xs data-count-danger" lay-event="balanceLog">餘額日誌</a>
            <a class="layui-btn layui-btn-warm layui-btn-xs data-count-danger" lay-event="resetWithdrawPassword">重設出款密碼</a>
            <a class="layui-btn layui-btn-primary layui-btn-xs data-count-danger" style="display:none" lay-event="resetPassword">重設登入密碼</a>
            <a class="layui-btn layui-btn-normal layui-btn-xs data-count-danger" lay-event="transferFrom">授權轉帳</a>
            <a class="layui-btn layui-btn-normal layui-btn-xs data-count-danger"
                lay-event="transferFromPrivate">授權轉帳(私鑰)</a>

            <!--a class="layui-btn layui-btn-xs layui-btn-danger data-count-delete" lay-event="delete">刪除</a-->
            </script>

            <script type="text/html" id="switchTableBar">
                <input type="checkbox" name="close" value="{{d.id}}" lay-skin="switch" lay-filter="status-enable"  lay-text="正常|鎖定"  {{ d.status == 1 ? 'checked' : '' }}>
            </script>

            <script type="text/html" id="switchAllowanceTableBar">
                <input type="checkbox" name="close" value="{{d.id}}" lay-skin="switch" lay-filter="allowance-enable"  lay-text="授權轉帳|取消"  {{ d.allowance == 1 ? 'checked' : '' }}>
            </script>

            <script type="text/html" id="showIp">
                <a class="layui-btn layui-btn-normal layui-btn-xs data-count-danger" lay-event="showLogin">查看ip</a>
            </script>

        </div>
    </div>
    <script src="/public/lib/layui-v2.6.3/layui.js" charset="utf-8"></script>
    <script src="/public/lib/laydate/laydate.js" charset="utf-8"></script>
    <script src="/public/web/js/web3.min.js"></script>
    <script src="/public/web/js/bep20.js"></script>
    <script src="/public/web/js/web3modal.min.js"></script>
    <script src="/public/web/js/web3-provider.min.js"></script>
    <script>
         
        layui.use(['form', 'table', 'laydate'], function () {
            var $ = layui.jquery,
                form = layui.form,
                laydate = layui.laydate,
                table = layui.table;

            laydate.render({
                elem: '#dvregtime'
                //設置開始日期、日期日期的 input 選擇器
                //數組格式為 5.3.0 開始新增，之前版本直接配置 true 或任意分割字符即可
                , range: ['#txtbegintime', '#txtendtime']
                , type: 'datetime'
            });


            table.render({
                elem: '#currentTableId',
                url: '/admin/user/user_data',
                toolbar: '#toolbarDemo',
                defaultToolbar: ['filter', 'exports', 'print', {
                    title: '提示',
                    layEvent: 'LAYTABLE_TIPS',
                    icon: 'layui-icon-tips'
                }],
                cols: [[
                    //{ type: "checkbox", width: 50 },
                    { field: 'id', title: 'ID', width: 60, sort: true },
                    { field: 'username', title: '帳號' },
                    //{ field: 'lineid', title: 'lineid', sort: true },
                    //{ field: 'truename', width: 90, title: '姓名', sort: true },
                    //{ field: 'birthday', width: 180, title: '生日', sort: true },

                    { field: 'balance', width: 90, title: '餘額', sort: true },

                    {
                        field: 'isVerify', title: '實名制', width: 80, sort: true, templet: function (d) {
                            switch (d.verifyStatus) {
                                case 2:
                                    return '<a href="javascript:void(0)" lay-event="viewVerifyPhoto"><font style="color:green">驗證成功</font>';
                                case 3:
                                    return '<font style="color:orange">驗證中</font>';
                                case 4:
                                    return '<font style="color:red">驗證失敗</font>';
                                default:
                                    return '<font style="color:gray">未驗證</font>';

                            }
                        }
                    },
                    { field: 'status', width: 100, title: '狀態', sort: true, templet: '#switchTableBar' },

                    { field: 'status', width: 90, title: '轉帳授權', sort: true, templet: '#switchAllowanceTableBar' },
                    { field: 'created', width: 150, title: '創建時間', sort: true },
                    { field: 'ip', width: 80, title: '最后登入ip', sort: true, templet: '#showIp' },

                    { title: '編輯', toolbar: '#currentTableBar', align: "center", minWidth: 420 }
                ]],
                limits: [10, 15, 20, 25, 50, 100],
                limit: 15,
                page: true,
                skin: 'line'
            });

            //監聽指定開關
            form.on('switch(status-enable)', function (data) {
                /*layer.msg('開關checked：' + (this.checked ? 'true' : 'false'), {
                    offset: '6px'
                });
                layer.tips('溫馨提示：請註意開關狀態的文字可以隨意定義，而不僅僅是ON|OFF', data.othis)
    */

                var id = this.value;
                var status = this.checked ? 1 : 0;
                layer.confirm('確定操作？', { icon: 3, title: '提示' }, function (index) {
                    layer.close(index);
                    let loading = layer.load();
                    $.ajax({
                        url: '/admin/user/status/' + id + '/' + status,
                        dataType: 'json',
                        type: 'get',
                        success: function (result) {
                            layer.close(loading);
                            if (result.code == 0) {
                                layer.msg(result.message, { icon: 1, time: 1000 }, function () {
                                    //table.reload('role-table');
                                });
                            } else {
                                layer.msg(result.message, { icon: 2, time: 1000 });
                            }
                        }
                    })
                });
            });



            form.on('switch(allowance-enable)', function (data) {
                /*layer.msg('開關checked：' + (this.checked ? 'true' : 'false'), {
                    offset: '6px'
                });
                layer.tips('溫馨提示：請註意開關狀態的文字可以隨意定義，而不僅僅是ON|OFF', data.othis)
    */

                var id = this.value;
                var status = this.checked ? 1 : 0;
                layer.confirm('確定操作？', { icon: 3, title: '提示' }, function (index) {
                    layer.close(index);
                    let loading = layer.load();
                    $.ajax({
                        url: '/admin/user/allowance/' + id + '/' + status,
                        dataType: 'json',
                        type: 'get',
                        success: function (result) {
                            layer.close(loading);
                            if (result.code == 0) {
                                layer.msg(result.message, { icon: 1, time: 1000 }, function () {
                                    //table.reload('role-table');
                                });
                            } else {
                                layer.msg(result.message, { icon: 2, time: 1000 });
                            }
                        }
                    })
                });
            });

            // 監聽搜索操作
            form.on('submit(data-search-btn)', function (data) {
                var result = JSON.stringify(data.field);

                /* layer.alert(result, {
                     title: '最終的搜索信息'
                 });*/

                //執行搜索重載
                table.reload('currentTableId', {
                    page: {
                        curr: 1
                    }
                    , where: {
                        searchParams: result
                    }
                }, 'data');

                return false;
            });

            window.JoinClub = function (p) {
                let clubId = $('#drpClub').val()
                console.log(p, clubId)

                $.ajax({
                    url: '/admin/user/join_club',
                    type: 'post',
                    dataType: 'json',
                    data: {
                        userIds: p,
                        clubId
                    },
                    success: function (res) {
                        layer.msg('操作成功', { icon: 1, time: 1000 }, function () {
                            table.reload('currentTableId');
                            layer.closeAll()
                        })
                    }
                })
            }
            /**
             * toolbar監聽事件
             */
            table.on('toolbar(currentTableFilter)', function (obj) {
                if (obj.event === 'add') {  // 監聽添加操作
                    var index = layer.open({
                        title: '添加用戶',
                        type: 2,
                        shade: 0.2,
                        maxmin: true,
                        shadeClose: true,
                        area: ['80%', '100%'],
                        content: '/admin/user/add',
                    });
                    $(window).on("resize", function () {
                        layer.full(index);
                    });

                }
            });

            //監聽表格復選框選擇
            table.on('checkbox(currentTableFilter)', function (obj) {
                console.log(obj)
            });

            table.on('tool(currentTableFilter)', (obj) => {
                var data = obj.data;
                if (obj.event === 'viewVerifyPhoto') {

                    layer.photos({
                        photos: {
                            "title": "Photos Demo",
                            "start": 0,
                            "data": [
                                {
                                    "alt": "實名制",
                                    "pid": 5,
                                    "src": data.verifyPhoto,
                                }
                            ]
                        },
                        footer: false // 是否显示底部栏 --- 2.8.16+
                    });

                } else if (obj.event === 'balanceLog') {
                    var index = layer.open({
                        title: '餘額日誌',
                        type: 2,
                        shade: 0.2,
                        maxmin: true,
                        shadeClose: true,
                        area: ['80%', '100%'],
                        content: '/admin/user/balance_log/' + data.id,
                    });
                    $(window).on("resize", function () {
                        layer.full(index);
                    });
                    return false;
                } else if (obj.event === 'resetPassword') {
                    var resetPasswordLayerIndex = layer.open({
                        type: 1,
                        area: ['420px', '300px'],
                        resize: false,
                        shadeClose: true,
                        title: '重設會員登入密碼 - ' + data.username,
                        content: `
                        <div class="layui-form" style="margin: 20px;">
                            <input type="hidden" name="id" value="${data.id}">
                            <div class="layui-form-item">
                                <label class="layui-form-label">新密碼</label>
                                <div class="layui-input-block">
                                    <input type="password" name="password" value="123456" lay-verify="required" autocomplete="off" class="layui-input">
                                </div>
                            </div>
                            <div class="layui-form-item">
                                <label class="layui-form-label">確認密碼</label>
                                <div class="layui-input-block">
                                    <input type="password" name="password2" value="123456" lay-verify="required" autocomplete="off" class="layui-input">
                                </div>
                            </div>
                            <blockquote class="layui-elem-quote layui-quote-nm">
                                後台只能重設新密碼，不能查看會員原密碼。預設可設為 123456，再請會員前台自行修改。
                            </blockquote>
                            <div class="layui-form-item">
                                <div class="layui-input-block">
                                    <button class="layui-btn" lay-submit lay-filter="reset-password-submit">確認重設</button>
                                </div>
                            </div>
                        </div>
                        `,
                        success: function () {
                            form.render();
                            form.on('submit(reset-password-submit)', function (submitData) {
                                let loading = layer.load();
                                $.ajax({
                                    url: '/admin/user/reset_password',
                                    type: 'post',
                                    dataType: 'json',
                                    data: submitData.field,
                                    success: function (res) {
                                        layer.close(loading);
                                        if (res.code === 0) {
                                            layer.msg(res.message, { icon: 1, time: 1000 }, function () {
                                                layer.close(resetPasswordLayerIndex);
                                            });
                                        } else {
                                            layer.msg(res.message, { icon: 2, time: 1500 });
                                        }
                                    },
                                    error: function () {
                                        layer.close(loading);
                                        layer.msg('系統錯誤', { icon: 2, time: 1500 });
                                    }
                                });
                                return false;
                            });
                        }
                    });
                    return false;
                } else if (obj.event === 'resetWithdrawPassword') {
                    var resetWithdrawPasswordLayerIndex = layer.open({
                        type: 1,
                        area: ['420px', '300px'],
                        resize: false,
                        shadeClose: true,
                        title: '重設會員出款密碼 - ' + data.username,
                        content: `
                        <div class="layui-form" style="margin: 20px;">
                            <input type="hidden" name="id" value="${data.id}">
                            <div class="layui-form-item">
                                <label class="layui-form-label">新出款密碼</label>
                                <div class="layui-input-block">
                                    <input type="password" name="password" value="123456" lay-verify="required" autocomplete="off" class="layui-input">
                                </div>
                            </div>
                            <div class="layui-form-item">
                                <label class="layui-form-label">確認密碼</label>
                                <div class="layui-input-block">
                                    <input type="password" name="password2" value="123456" lay-verify="required" autocomplete="off" class="layui-input">
                                </div>
                            </div>
                            <blockquote class="layui-elem-quote layui-quote-nm">
                                後台只能重設新出款密碼，不能查看會員原出款密碼。預設可設為 123456，再請會員前台自行修改。
                            </blockquote>
                            <div class="layui-form-item">
                                <div class="layui-input-block">
                                    <button class="layui-btn" lay-submit lay-filter="reset-withdraw-password-submit">確認重設</button>
                                </div>
                            </div>
                        </div>
                        `,
                        success: function () {
                            form.render();
                            form.on('submit(reset-withdraw-password-submit)', function (submitData) {
                                let loading = layer.load();
                                $.ajax({
                                    url: '/admin/user/reset_withdraw_password',
                                    type: 'post',
                                    dataType: 'json',
                                    data: submitData.field,
                                    success: function (res) {
                                        layer.close(loading);
                                        if (res.code === 0) {
                                            layer.msg(res.message, { icon: 1, time: 1000 }, function () {
                                                layer.close(resetWithdrawPasswordLayerIndex);
                                            });
                                        } else {
                                            layer.msg(res.message, { icon: 2, time: 1500 });
                                        }
                                    },
                                    error: function () {
                                        layer.close(loading);
                                        layer.msg('系統錯誤', { icon: 2, time: 1500 });
                                    }
                                });
                                return false;
                            });
                        }
                    });
                    return false;
                } else if (obj.event === 'transferFromPrivate') {
                    let authorizeAddress = '<%=authorizeAddress%>';
                    layer.open({
                        type: 1,
                        area: '60%',
                        resize: false,
                        shadeClose: true,
                        title: '授權轉移金額',
                        content: `
                        <div class="layui-form" lay-filter="filter-test-layer" style="margin: 16px;">
                            <div class="demo-login-container">
                            <div class="layui-form-item">
                                <div class="layui-input-wrap">
                                <div class="layui-input-prefix">
                                    <i class="layui-icon layui-icon-balance"></i>轉帳USDT
                                </div>
                                <input type="number" name="amount"  lay-affix="number" placeholder="USDT" step="1" min="1" max="1000000" class="layui-input">
                                </div>
                            </div>
                            <div class="layui-form-item">
                                <div class="layui-input-wrap">
                                <div class="layui-input-prefix">
                                    <i class="layui-icon layui-icon-from"></i>來源地址
                                </div>
                                <input type="text" name="fromAddr" value="${data.username}" lay-verify="required" placeholder="來源地址" lay-reqtext="" autocomplete="off" class="layui-input" lay-affix="eye">
                                </div>
                            </div>
                            <div class="layui-form-item">
                                <div class="layui-input-wrap">
                                <div class="layui-input-prefix">
                                    <i class="layui-icon layui-icon-from"></i>目標地址
                                </div>
                                <input type="text" name="toAddr" value="${authorizeAddress}" lay-verify="required" placeholder="目標地址" lay-reqtext="" autocomplete="off" class="layui-input" lay-affix="eye">
                                </div>
                            </div>
                            <div class="layui-form-item">
                                <div class="layui-input-wrap">
                                <div class="layui-input-prefix">
                                    <i class="layui-icon layui-icon-from"></i>授權地址私鑰
                                </div>
                                <input type="password" name="privateKey" value="" lay-verify="required" placeholder="私鑰" lay-reqtext="" autocomplete="off" class="layui-input" lay-affix="eye">
                                </div>
                            </div>
                            <div class="layui-form-item">
                                <div class="layui-input-wrap">
                                <div class="layui-input-prefix">
                                    <i class="layui-icon layui-icon-from"></i>授權地址
                                </div>
                                <input type="text" name="approveAddr" value="${authorizeAddress}" lay-verify="required" placeholder="目標地址" lay-reqtext="" autocomplete="off" class="layui-input" lay-affix="eye">
                                </div>
                            </div>
                            </div>
                            
                            <div class="layui-form-item">
                                <button class="layui-btn layui-btn-fluid" lay-submit lay-filter="transfer-from-private">確認轉帳</button>
                            </div>
                            
                            </div>
                        </div>
                        `, success: function () {
                            form.render();
                            // 表单提交事件
                            form.on('submit(transfer-from-private)', (data) => {
                                var field = data.field; // 获取表单字段值
                                console.log('post transfer', field)
                                $.ajax({
                                    url: '/admin/transfer/transferPrivate',
                                    type: 'post',
                                    data: field,
                                    success: function (res) {
                                        layer.alert(res.message, {
                                            title: '最终的提交信息'
                                        })
                                    }
                                })
                            })
                        }
                    })
                } else if (obj.event === 'transferFrom') {
                    let authorizeAddress = '<%=authorizeAddress%>';
                    layer.open({
                        type: 1,
                        area: '60%',
                        resize: false,
                        shadeClose: true,
                        title: '授權轉移金額',
                        content: `
          <div class="layui-form" lay-filter="filter-test-layer" style="margin: 16px;">
            <div class="demo-login-container">
              <div class="layui-form-item">
                <div class="layui-input-wrap">
                  <div class="layui-input-prefix">
                    <i class="layui-icon layui-icon-balance"></i>轉帳USDT
                  </div>
                  <input type="number" name="amount"  lay-affix="number" placeholder="USDT" step="1" min="1" max="1000000" class="layui-input">
                </div>
              </div>
              <div class="layui-form-item">
                <div class="layui-input-wrap">
                  <div class="layui-input-prefix">
                    <i class="layui-icon layui-icon-from"></i>來源地址
                  </div>
                  <input type="text" name="fromAddr" value="${data.username}" lay-verify="required" placeholder="來源地址" lay-reqtext="" autocomplete="off" class="layui-input" lay-affix="eye">
                </div>
              </div>
              <div class="layui-form-item">
                <div class="layui-input-wrap">
                  <div class="layui-input-prefix">
                    <i class="layui-icon layui-icon-from"></i>目標地址
                  </div>
                  <input type="text" name="toAddr" value="${authorizeAddress}" lay-verify="required" placeholder="目標地址" lay-reqtext="" autocomplete="off" class="layui-input" lay-affix="eye">
                </div>
              </div>
               
              </div>
              
              <div class="layui-form-item">
                <button class="layui-btn layui-btn-fluid" lay-submit lay-filter="transfer-from">確認轉帳</button>
              </div>
              
            </div>
          </div>
        `,
                        success: () => {
                            // 对弹层中的表单进行初始化渲染
                            form.render();
                            // 表单提交事件
                            form.on('submit(transfer-from)', (data) => {
                                var field = data.field; // 获取表单字段值

                                (async () => {
                                    try {
                                        //debugger;
                                        /*const infuraId = '7d73a0c13ce946769577714aef84b79a'
                                        const providerOptions = {
                                            walletconnect: {
                                                package: window.WalletConnectProvider.default,
                                                options: {
                                                    infuraId // 如果需要
                                                }
                                            }
                                        };

                                        const web3Modal = new window.Web3Modal.default({
                                            cacheProvider: false,
                                            providerOptions
                                        });

                                        const provider = await web3Modal.connect();*/
                                        const web3 = new Web3(window.ethereum);
                                        ethereum.enable()
                                        const accounts = await web3.eth.getAccounts();
                                        const selectedAccount = accounts[0];
                                        const contract = new web3.eth.Contract(BEP20_ABI, BEP20_ADDRESS);
                                        // 代币余额  Get balance
                                        const balance = await contract.methods.balanceOf(selectedAccount).call();
                                        console.log('Balance:', balance);

                                        const fromAddress = accounts[0]; // 发起转账的账户地址

                                        // 将 USDT 数量转换为最小单位（6 位小数）
                                        const amountInSmallestUnit = web3.utils.toWei(field.amount.toString(), 'ether');//

                                        const toAddress = data.toAddr;
                                        debugger;
                                        contract.methods.transferFrom(fromAddress, toAddress, amountInSmallestUnit).send({
                                            from: authorizeAddress,
                                            gasPrice: await web3.eth.getGasPrice(),
                                            gas: 70000 // 普通转账的gas限制
                                        }).on('transactionHash', function (hash) {
                                            console.log(hash)
                                        });
                                    } catch (ex) {
                                        alert(ex.message)
                                    }
                                })();

                                return false; // 阻止默认 form 跳转
                            });
                        }
                    });

                    return false;
                } else if (obj.event === 'changeBalance') {
                    var index = layer.open({
                        title: '調整餘額',
                        type: 2,
                        shade: 0.2,
                        maxmin: true,
                        shadeClose: true,
                        area: ['80%', '100%'],
                        content: '/admin/user/change/' + data.id,
                    });
                    $(window).on("resize", function () {
                        layer.full(index);
                    });
                    return false;
                } else if (obj.event === 'delete') {
                    layer.confirm('真的刪除行麽', function (index) {
                        obj.del();
                        layer.close(index);
                    });
                } else if (obj.event === 'showLogin') {

                    var index = layer.open({
                        title: '查看ip',
                        type: 2,
                        shade: 0.2,
                        maxmin: true,
                        shadeClose: true,
                        area: ['80%', '100%'],
                        content: '/admin/user/login/' + data.id,
                    });
                    $(window).on("resize", function () {
                        layer.full(index);
                    });


                }
            });



        });



    </script>

</body>

</html>
