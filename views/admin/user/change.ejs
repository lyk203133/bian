<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>layui</title>
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <link rel="stylesheet" href="/public/lib/layui-v2.6.3/css/layui.css" media="all">
    <link rel="stylesheet" href="/public/css/public.css" media="all">
</head>

<body>
    <div class="layuimini-container">
        <div class="layuimini-main">

            <!--blockquote class="layui-elem-quote layui-text">
           会员资料 
        </blockquote-->

            <fieldset class="layui-elem-field layui-field-title" style="margin-top: 20px;">
                <legend>USDT管理</legend>
            </fieldset>

            <form class="layui-form">


                <!--div class="layui-form-item">
                    <div class="layui-inline">
                        <label class="layui-form-label">類別</label>
                        <div class="layui-input-inline">
                            <select type="text" id="type" name="type" autocomplete="off" class="layui-input">
                                <option value="">請選擇類別</option>
                                <option value="9">一般點數</option>
                                <option value="7">活動點數</option>
                                <option value="8">自辦點數</option>
                            </select>
                        </div>
                    </div>
                </div-->
                <div class="layui-form-item">
                    <div class="layui-inline">
                        <label class="layui-form-label">USDT</label>
                        <div class="layui-input-block">
                            <input type="balance" name="amount" id="amount" placeholder="請輸入USDT" autocomplete="off"
                                class="layui-input">
                        </div>
                    </div>
                </div>
                <div class="layui-inline">
                    <button id="add" class="layui-btn" type="button" lay-event="changeBalance">後台上分</button>
                </div>
                <div class="layui-inline">
                    <button id="sub" class="layui-btn" type="button" lay-event="changeBalance">後台下分</button>
                </div>
        </div>

        </form>

    </div>
    </div>

    <script src="/public/lib/layui-v2.6.3/layui.js" charset="utf-8"></script>
    <script src="/public/lib/jquery-3.4.1/jquery-3.4.1.min.js" charset="utf-8"></script>
    <!-- 注意：如果你直接复制所有代码到本地，上述js路径需要改成你本地的 -->
    <script>
        layui.use(['form', 'layedit', 'laydate'], function () {
            var form = layui.form
                , layer = layui.layer

            //监听提交
            $('#add').click(function () {
                let amount = $('#amount').val();
                if (amount == '' || parseInt(amount) <= 0) {
                    layer.alert('點數不能为空或小於0', {
                        title: 'error'
                    })
                    return false;
                }
                $.ajax({
                    url: '/admin/user/change/add',
                    type: 'post',
                    data: {
                        userId: '<%=id%>',
                        amount: amount,
                        type: 9
                    },
                    success: function (res) {
                        console.log(res);
                        layer.alert(res.message)
                        if (res.code != undefined && res.code === 0) {
                            parent.window.location.reload();
                        }

                    }
                })
            });

            $('#sub').click(function () {
                let amount = $('#amount').val();
                if (amount == '' || parseInt(amount) < 0) {
                    layer.alert('點數不能为空或小於0', {
                        title: 'error'
                    })
                    return false;
                }
                $.ajax({
                    url: '/admin/user/change/sub',
                    type: 'post',
                    data: {
                        userId: '<%=id%>',
                        amount: amount,
                        type: 9
                    },
                    success: function (res) {
                        console.log(res);
                        if (res.code === 0) {
                            var index = parent.layer.getFrameIndex(window.name);
                            parent.layer.close(index);
                            layer.close()
                            parent.window.location.reload();

                        }
                    }
                })
            });

        });
    </script>
</body>

</html>