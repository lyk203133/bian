<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>layui</title>
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <link rel="stylesheet" href="/public/lib/layui-v2.6.3/css/layui.css" media="all">
    <link rel="stylesheet" href="/public/css/public.css" media="all">
    <style>
        .task-title {
            padding: 9px 15px;
            font-weight: 400;
            line-height: 20px;
            color: var(--color-w100);
            letter-spacing: 0.03rem;
        }
    </style>
</head>

<body>
    <div class="layuimini-container">
        <div class="layuimini-main">
            <fieldset class="layui-elem-field layui-field-title" style="margin-top: 20px;">
                <legend>審核資料詳情</legend>
            </fieldset>
            <div class="layui-form-item">
                <label class="layui-form-label">會員名稱</label>
                <div class="layui-input-block">
                    <span class="layui-input">
                        <%=data.username%>
                    </span>
                </div>
            </div>

            <!-- 實名驗證 -->

            <div>

                <div class="layui-form-item">
                    <label class="layui-form-label">
                        <%=data.platform=='幣安' ? '手機' :'信箱'%>
                    </label>
                    <div class="layui-input-block">
                        <span class="layui-input">
                            <%=data.info%>
                        </span>
                    </div>
                </div>
                <div class="layui-form-item">
                    <label class="layui-form-label">平臺</label>
                    <div class="layui-input-block">
                        <span class="layui-input">
                            <%=data.platform%>
                        </span>
                    </div>
                </div>
                <div class="layui-form-item">
                    <label class="layui-form-label">備註</label>
                    <div class="layui-input-block">
                        <span class="layui-input">
                            <%=data.remark%>
                        </span>
                    </div>
                </div>
            </div>

            <div class="layui-form-item">
                <label class="layui-form-label">任務圖片</label>

                <div class="layui-input-block">
                    <img src="<%=data.photo%>" style="width:150px" />
                </div>
            </div>

        </div>
    </div>

</body>

</html>