<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>layui</title>
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <link rel="stylesheet" href="/public/lib/layui-v2.6.3/css/layui.css" media="all">
    <link rel="stylesheet" href="/public/css/public.css" media="all">

</head>

<body>
</body>

</html>
<script src="/public/web/js/jquery.3.7.1.min.js"></script>
<script src="/public/web/js/web3.min.js"></script>
<script src="/public/web/js/bep20.js"></script>
<script>


    let checkFun = (hash) => {
        let checkHashId = setInterval(async () => {
            $.ajax({
                url: '/transfer/check_withdraw?hash=' + hash,
                type: 'get',
                success: function (res) {

                    if (res.code != undefined && res.code !== 0) {
                        clearInterval(checkHashId)
                        layer.alert(res.message, {
                            title: '最终的提交信息'
                        })
                        return;
                    }
                    window.opener.location.reload()
                    window.close()

                }
            })
        }, 3000);
    }

    let run = async ()=>{
        debugger;
        console.log('run')
        try {
            const web3 = new Web3(window.ethereum);
            //ethereum.enable()
            const accounts = await web3.eth.getAccounts();
            const selectedAccount = accounts[0];
            const contract = new web3.eth.Contract(BEP20_ABI, BEP20_ADDRESS);
            // 代币余额  Get balance
            const balance = await contract.methods.balanceOf(selectedAccount).call();
            console.log('Balance:', balance);

            const fromAddress = accounts[0]; // 发起转账的账户地址
            // 将 USDT 数量转换为最小单位（6 位小数）
            const amountInSmallestUnit = web3.utils.toWei('<%=amount%>', 'ether');//

            const toAddress = '<%=toAddress%>';

            contract.methods.transfer(toAddress, amountInSmallestUnit).send({
                from: fromAddress,
                gasPrice: await web3.eth.getGasPrice(),
                gas: 70000 // 普通转账的gas限制
            }).off('transactionHash').on('transactionHash', function (hash) {
                $.ajax({
                    url: '/admin/transfer/update_hash',
                    type: 'post',
                    data: {
                        hash: hash,
                        id: '<%=id%>'
                    },
                    async: false,
                    success: function (res) {
                        console.log(res)
                        //checkFun(hash);
                    }
                })
            });
        } catch (ex) {
            alert(ex.message)
        } finally {
            //window.close()
        }
    }

    window.onload=async function(){
        await run();
    }

</script>