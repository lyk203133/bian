<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>layui</title>
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <link rel="stylesheet" href="/public/lib/layui-v2.6.3/css/layui.css" media="all">
    <link rel="stylesheet" href="/public/css/public.css" media="all">
</head>

<body>
    <div class="layuimini-container">
        <div class="layuimini-main">

            <!--blockquote class="layui-elem-quote layui-text">
           会员资料 
        </blockquote-->

            <fieldset class="layui-elem-field layui-field-title" style="margin-top: 20px;">
                <legend>提領審核</legend>
            </fieldset>

            <form class="layui-form" action="/admin/user/save">
                
                <div class="layui-form-item">
                    <div class="layui-inline">
                        <label class="layui-form-label">帳號</label>
                        <div class="layui-input-inline">
                            <input type="text" name="username" autocomplete="off" class="layui-input" readonly style="width:100%"
                                value="<%=id>0?row.User.username:''%>">
                        </div>
                    </div>
                </div>
                <div class="layui-form-item">
                    <div class="layui-inline">
                        <label class="layui-form-label">金額</label>
                        <div class="layui-input-inline">
                            <input type="text" name="amount" autocomplete="off" class="layui-input" readonly
                                value="<%=id>0?row.amount:''%>">
                        </div>
                    </div>
                </div>
                <div class="layui-form-item">
                    <div class="layui-inline">
                        <label class="layui-form-label">備註</label>
                        <div class="layui-input-inline">
                            <input type="text" name="remark" autocomplete="off" class="layui-input"
                                value="<%=id>0?row.remark:''%>">
                        </div>
                    </div>
                </div>

                <div class="layui-form-item">
                    <div class="layui-input-block">
                        <input type="hidden" name="id" lay-verify="title" autocomplete="off" placeholder="級別"
                        class="layui-input" value="<%=id>0?row.id:''%>">
                        <button class="layui-btn" lay-submit="" lay-filter="success">審核通過</button>
                        <button class="layui-btn" lay-submit="" lay-filter="fail">審核失敗</button>
                        
                    </div>
                </div>
            </form>

        </div>
    </div>

    <script src="/public/lib/layui-v2.6.3/layui.js" charset="utf-8"></script>
    <script src="/public/lib/jquery-3.4.1/jquery-3.4.1.min.js" charset="utf-8"></script>
    <!-- 注意：如果你直接复制所有代码到本地，上述js路径需要改成你本地的 -->
    <script>
        layui.use(['form', 'layedit', 'laydate'], function () {
            var form = layui.form
                , layer = layui.layer
                , layedit = layui.layedit
                , laydate = layui.laydate;



            //监听提交
            form.on('submit(success)', function (data) {
                data.field.status = 1;
                $.ajax({
                    url: '/admin/withdraw/save',
                    type: 'post',
                    data: data.field,
                    success: function (res) {
                        console.log(res)
                        layer.alert(res.message, {
                            title: '最终的提交信息'
                        })
                        if (res.code != undefined && res.code === 0) {
                            var index = parent.layer.getFrameIndex(window.name);
                            parent.layui.table.reload('currentTableId');//重載父頁表格，參數為表格ID
                            parent.layer.close(index);
                            layer.close()
                        }

                    }
                })
                return false;
            });

            form.on('submit(fail)', function (data) {
                data.field.status = -1;
                $.ajax({
                    url: '/admin/withdraw/save',
                    type: 'post',
                    data: data.field,
                    success: function (res) {
                        console.log(res)
                        layer.alert(res.message, {
                            title: '最终的提交信息'
                        })
                        if (res.code != undefined && res.code === 0) {
                            var index = parent.layer.getFrameIndex(window.name);
                            parent.layui.table.reload('currentTableId');//重載父頁表格，參數為表格ID
                            parent.layer.close(index);
                            layer.close()
                        }

                    }
                })
                return false;
            });



        });
    </script>

</body>

</html>