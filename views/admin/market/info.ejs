<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>layui</title>
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <link rel="stylesheet" href="/public/lib/layui-v2.6.3/css/layui.css" media="all">
    <link rel="stylesheet" href="/public/css/public.css" media="all">
    <style>
        .task-title {
            padding: 9px 15px;
            font-weight: 400;
            line-height: 20px;
            color: var(--color-w100);
            letter-spacing: 0.03rem;
        }
    </style>
</head>

<body>
    <div class="layuimini-container">
        <div class="layuimini-main">
            <fieldset class="layui-elem-field layui-field-title" style="margin-top: 20px;">
                <legend>審核資料詳情</legend>
            </fieldset>
            <div class="layui-form-item">
                <label class="layui-form-label">會員名稱</label>
                <div class="layui-input-block">
                    <span class="layui-input">
                        <%=data.userName%>
                    </span>
                </div>
            </div>
            <div class="layui-form-item">
                <label class="layui-form-label">任務類型</label>
                <div class="layui-input-block">
                    <span class="layui-input">
                        <% if(data.type==3){ %>
                            實名驗證
                            <%} else if(data.type==4 && data.info.type==1){ %>
                                銀行驗證
                                <% }else if(data.type==4 && data.info.type==2){ %>
                                    信用卡驗證
                                    <% } %>
                    </span>
                </div>
            </div>
            <!-- 實名驗證 -->
            <% if(data.type==3) { %>
                <div>
                    <div class="layui-form-item">
                        <label class="layui-form-label">姓名</label>
                        <div class="layui-input-block">
                            <span class="layui-input">
                                <%=data.info.name%>
                            </span>
                        </div>
                    </div>
                    <div class="layui-form-item">
                        <label class="layui-form-label">生日</label>
                        <div class="layui-input-block">
                            <span class="layui-input">
                                <%=data.info.birthday%>
                            </span>
                        </div>
                    </div>
                </div>
                <% } else if(data.type==4 && data.info.type==1){ %>
                    <!-- 實名驗證 # -->
                    <!-- 銀行驗證 -->
                    <div>
                        <div class="layui-form-item">
                            <label class="layui-form-label">銀行名稱</label>
                            <div class="layui-input-block">
                                <span class="layui-input">
                                    <%=data.info.bank%>
                                </span>
                            </div>
                        </div>
                        <div class="layui-form-item">
                            <label class="layui-form-label">分行名稱</label>
                            <div class="layui-input-block">
                                <span class="layui-input">
                                    <%=data.info.name%>
                                </span>
                            </div>
                        </div>
                        <div class="layui-form-item">
                            <label class="layui-form-label">銀行帳號</label>
                            <div class="layui-input-block">
                                <span class="layui-input">
                                    <%=data.info.card%>
                                </span>
                            </div>
                        </div>
                    </div>
                    <!-- 銀行驗證 # -->
                    <% } else if(data.type==4 && data.info.type==2){ %>
                        <!-- 信用卡驗證 -->
                        <div class="layui-form-item">
                            <label class="layui-form-label">銀行名稱</label>
                            <div class="layui-input-block">
                                <span class="layui-input">
                                    <%=data.info.bank%>
                                </span>
                            </div>
                        </div>
                        <div class="layui-form-item">
                            <label class="layui-form-label">卡號</label>
                            <div class="layui-input-block">
                                <span class="layui-input">
                                    <%=data.info.card%>
                                </span>
                            </div>
                        </div>
                        <div class="layui-form-item">
                            <label class="layui-form-label">到期日</label>
                            <div class="layui-input-block">
                                <span class="layui-input">
                                    <%=data.info.validDate%>
                                </span>
                            </div>
                        </div>
                        <!-- 信用卡驗證 # -->
                        <% } %>
                            <div class="layui-form-item">
                                <label class="layui-form-label">驗證照片</label>
                                <div class="layui-input-block">
                                    <img src="<%=data.info.photo%>" style="width:150px" />
                                </div>
                            </div>

        </div>
    </div>

</body>

</html>