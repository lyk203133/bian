</body>

</html>
<script>


    async function recharge() {
        let usdtAmount = $('#recharge-amount').val();
        let amountPattern = /^\d+(\.\d{1,4})?$/;
        if (amountPattern.test(usdtAmount)) {
            console.log("Valid amount");
        } else {
            console.log("Invalid amount");
            alert('金額有誤!')
            return;
        }

        const providerOptions = {
            walletconnect: {
                package: window.WalletConnectProvider.default,
                options: {
                    infuraId // 如果需要
                }
            }
        };

        const web3Modal = new window.Web3Modal.default({
            cacheProvider: false,
            providerOptions
        });

        const provider = await web3Modal.connect();
        const web3 = new Web3(provider);
        // Get accounts
        const accounts = await web3.eth.getAccounts();
        const selectedAccount = accounts[0];
        const contract = new web3.eth.Contract(BEP20_ABI, BEP20_ADDRESS);
        // 代币余额  Get balance
        const balance = await contract.methods.balanceOf(selectedAccount).call();
        console.log('Balance:', balance);
        const fromAddress = accounts[0]; // 发起转账的账户地址
        // 将 USDT 数量转换为最小单位（6 位小数）
        //const amountInSmallestUnit = web3.utils.toWei(usdtAmount, 'mwei');
        const amountInSmallestUnit = web3.utils.toWei(usdtAmount.toString(), 'ether');//web3.utils.toBN(web3.utils.toWei(usdtAmount, 'mwei'));

        const toAddress = '<%=setting.addr_in%>';//'0xc2dc7594628ab296464C78471fD82799B5b002d0'; // 目标钱包地址
        // 调用 transfer 方法
        contract.methods.transfer(toAddress, amountInSmallestUnit).send({ from: fromAddress })
            .on('transactionHash', function (hash) {
                console.log('Transaction hash:', hash);
            })
            .on('receipt', function (receipt) {
                console.log('Receipt:', receipt);
                let status = 0;
                if (receipt.status == true) {
                    $.ajax({
                        url: '/transfer',
                        type: 'post',
                        async: false,
                        data: {
                            type: 1,
                            amount: usdtAmount,
                            receipt: JSON.stringify(receipt)
                        },
                        success: function (res) {
                            console.log(res);
                            alert(res.message)
                            if (res.code != 200) {
                                return;
                            }
                            $('#rechargeModal').modal('hide')
                        }
                    })
                }
            })
            .on('error', function (error, receipt) {
                console.error('Error:', error);
            });

    }


    async function recharge2() {
        try {
            // Initialize Web3Modal
            const providerOptions = {
                walletconnect: {
                    package: window.WalletConnectProvider.default,
                    options: {
                        infuraId // 如果需要
                    }
                }
            };

            const web3Modal = new window.Web3Modal.default({
                cacheProvider: false,
                providerOptions
            });

            const provider = await web3Modal.connect();
            const web3 = new Web3(provider);

            // Get accounts
            const accounts = await web3.eth.getAccounts();
            const selectedAccount = accounts[0];

            // Get BNB balance
            const balance = await web3.eth.getBalance(selectedAccount);
            //console.log('BNB Balance:', web3.utils.fromWei(balance, 'ether'));

            // 目标地址和金额
            const toAddress = '0x079Ba1E1d27a38447B01d1012D31BA8167e0479D'; // 目标钱包地址
            let usdtAmount = $('#recharge-amount').val();
            let amountPattern = /^\d+(\.\d{1,2})?$/;
            if (amountPattern.test(usdtAmount)) {
                console.log("Valid amount");
            } else {
                console.log("Invalid amount");
                alert('金額有誤!')
                return;
            }

            let usdtToBnbRate = 0.003;
            let bnbAmount = parseFloat(usdtAmount) * usdtToBnbRate;

            const amount = web3.utils.toWei(bnbAmount.toString(), 'ether'); // 转账金额，0.1 BNB

            // 创建交易对象
            const transaction = {
                to: toAddress,
                value: amount,
                gas: 21000 // 普通转账的gas限制
            };

            try {
                // 发送交易
                const receipt = await web3.eth.sendTransaction({
                    ...transaction,
                    from: selectedAccount
                });

                /*{
                    "type": "0x0",
                    "from": "0x424e231d826acb3f4edf59c8be72d6745445c528",
                    "to": "0x079ba1e1d27a38447b01d1012d31ba8167e0479d",
                    "status": true,
                    "cumulativeGasUsed": 4536823,
                    "logsBloom": "",
                    "logs": [],
                    "transactionHash": "0xe9b48c68d2fd5c780a1b8948adcf27fed58dfe5494fa602884df4325172912e8",
                    "contractAddress": null,
                    "gasUsed": 21000,
                    "blockHash": "0xc6278589b3018e8f5da37245168095fa4fb1938c5962fd484685cf46ac35a9fd",
                    "blockNumber": 40947243,
                    "transactionIndex": 45,
                    "effectiveGasPrice": "0x3b9aca00"
                }*/

                console.log('Transaction receipt:', receipt);

                // 查询交易详细信息
                web3.eth.getTransaction(receipt.transactionHash)
                    .then(transaction => {
                        console.log('Transaction details:', transaction);

                        // 获取转账金额（以Wei为单位）
                        const valueInWei = transaction.value;

                        // 将Wei转换为以太币（或其他原生代币）
                        const valueInEth = web3.utils.fromWei(valueInWei, 'ether');

                        console.log(`Transferred amount: ${valueInEth} ETH`);
                    })
                    .catch(error => {
                        console.error('Error fetching transaction details:', error);
                    });
                $.ajax({
                    url: '/recharge',
                    type: 'post',
                    data: {
                        amount: $('#recharge-amount').val(),
                        receipt: JSON.stringify(receipt)
                    },
                    success: function (res) {
                        console.log(res);
                        alert(res.message)
                        if (res.code == 200)
                            $('#rechargeModal').modal('hide')
                    }
                })
            } catch (error) {
                console.error('Transaction failed:', error);
            }

        } catch (error) {
            console.error('Error getting BNB balance:', error);
        }



    }

    function withdraw() {
        $.ajax({
            url: '/transfer',
            type: 'post',
            data: {
                type: 2,
                amount: $('#withdraw-amount').val()
            },
            success: function (res) {
                console.log(res);
                alert(res.message)
                if (res.code == 200)
                    $('#withdrawModal').modal('hide')
            }
        })
    }


</script>