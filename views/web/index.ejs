<script>


    function getData() {
        let rows = [];
        $.ajax({
            url: '/pricing',
            type: 'get',
            async: false,
            success: function (res) {
                console.log(res.data)
                for (let i in res.data) {
                    let item = res.data[i]
                    let currencyName = item.symbol.replace('USDT', '')
                    rows.push({
                        currencyName,
                        iconName: currencyName.toLowerCase(),
                        lastPrice: parseFloat(item.lastPrice).toFixed(2),
                        priceChange: parseFloat(item.priceChange).toFixed(2),
                    })
                }
            }
        })
        return rows;
    }

    function init() {
        let data = getData();
        var html = ''
        for (let i in data) {

            let item = data[i];
            html += `<tr data='${item.currencyName}' onclick="window.location='/market?symbol=${item.currencyName}USDT'">
                            <td>
                                <div class="item">
                                    <img class="icon" src="/public/web/images/${item.iconName}.png" />
                                    <span style="margin-left:.3rem">${item.currencyName}</span>
                                </div>
                            </td>
                            <td data='${item.lastPrice}'>
                                $${parseFloat(item.lastPrice).toFixed(2)}
                            </td>
                            <td>
                                $${parseFloat(item.priceChange).toFixed(2)}
                            </td>
                        </tr>`
        }

        $('#tbody').html(html)
    }

    init();

    setInterval(() => {
        let data = getData();
        $("tr[data]").each(function () {
            let currencyName = $(this).attr('data');
            console.log(currencyName)
            let row = data.find(d => d.currencyName == currencyName);
            if (row) {

                setPrice($(this), row.lastPrice, 1);
                setPrice($(this), row.priceChange, 2);
