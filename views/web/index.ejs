    function setPrice(obj, price, index) {
        let oriPrice = obj.find('td').eq(1).attr('data');
        if (oriPrice < price) {
            obj.find('td').eq(index).css('color', 'red');

        } else if (oriPrice > price) {
            obj.find('td').eq(index).css('color', 'green');
        }

        if (oriPrice != price) {
            obj.find('td').eq(index).attr('data', price)
            obj.find('td').eq(index).html('$' + price)
        }
    }


