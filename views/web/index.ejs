            let item = data[i];
            html += `<tr data='${item.currencyName}' onclick="window.location='/market?symbol=${item.currencyName}USDT'">
                            <td>
                                <div class="item">
                                    <img class="icon" src="/public/web/images/${item.iconName}.png" />
                                    <span style="margin-left:.3rem">${item.currencyName}</span>
                                </div>
                            </td>
                            <td data='${item.lastPrice}'>
                                $${parseFloat(item.lastPrice).toFixed(2)}
                            </td>
                            <td>

                                <svg style="margin-top:1.5rem" id="chart${i}" width="100" height="40"></svg>
                            </td>
                        </tr>`
            //$${parseFloat(item.priceChange).toFixed(2)}
        }

        $('#tbody').html(html)

        let drawFun = () => {
            for (let i in data) {
                let item = data[i];
                $.ajax({
                    url: '/market_data?symbol=' + item.currencyName + 'USDT&limit=150&interval=15m',
                    type: 'get',
                    success: function (res) {
                        let item_data = res.data.map((e, n) => {
                            return {
                                x: n * 50,
                                y: e[1]
                            }
                        })

                        draw('chart' + i, item_data)
                    }
                })



            }
        }
        setInterval(() => {
            drawFun();
        }, 30000)
        drawFun();
    }

