<script>


    function getData() {
        let rows = [];
        $.ajax({
            url: '/pricing',
            type: 'get',
            async: false,
            success: function (res) {
                console.log(res.data)
                for (let i in res.data) {
                    let item = res.data[i]
                    let currencyName = item.symbol.replace('USDT', '')
                    rows.push({
                        currencyName,
                        iconName: currencyName.toLowerCase(),
                        lastPrice: parseFloat(item.lastPrice).toFixed(2),
                        priceChange: parseFloat(item.priceChange).toFixed(2),
                    })
                }
            }
        })
        return rows;
    }

    function init() {
