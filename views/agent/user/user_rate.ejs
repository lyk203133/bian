        //保存每个盘口折扣或固定赔率
        function save_rate(id, type) {
            var $ = layui.jquery;

            let data = []
            if (type == 'discount') {
                $('input[key="score-' + id + '"]').each(function () {
                    let scoreid = $(this).attr('scoreid')
                    let val = $(this).val();
                    data.push({ scoreid: scoreid, discount: val })
                })
            } else if (type == 'fixed') {
                $('input[key="score-' + id + '"]').each(function () {
                    let scoreid = $(this).attr('scoreid')
                    let val = $(this).val();
                    data.push({ scoreid: scoreid, fixed: val })
                })
            } else if (type == 'gamemax') {
                $('input[key="score-gamemax-' + id + '"]').each(function () {
                    let scoreid = $(this).attr('scoreid')
                    let val = $(this).val();
                    data.push({ scoreid: scoreid, gamemax: val })
                })
            } else if (type == 'betmax') {
                $('input[key="score-betmax-' + id + '"]').each(function () {
                    let scoreid = $(this).attr('scoreid')
                    let val = $(this).val();
                    data.push({ scoreid: scoreid, betmax: val })
                })
            } else if (type == 'canbuy') {
                $('input[key="score-canbuy-' + id + '"]').each(function () {
                    let scoreid = $(this).attr('scoreid')
                    let val = $(this).val();
                    data.push({ scoreid: scoreid, canbuy: val })
                })
            }

            $.ajax({
                url: '/admin/user/user_rate/save/' + type,
                type: 'post',
                dataType: "json",
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    alert(res.message);
                    console.log(res.message);
                    $('#btnSearch').click()
                }

            })
        }

        //保存代理算式三总打折
        function save_agent_discount(type = 'discount') {
            var $ = layui.jquery;
            let data = []
            let id = type == 'all' ? 'all' : 0;
            if (type == 'op') {
                $('input[key="close-op"]').each(function () {
                    let cutline = $(this).attr('cutline')
                    let val = $(this).val();
                    data.push({ cutline: cutline, op: val })
                })
            } else if (type == 'ou') {
                $('input[key="close-ou"]').each(function () {
                    let cutline = $(this).attr('cutline')
                    let val = $(this).val();
                    data.push({ cutline: cutline, ou: val })
                })
            } else {
                $('input[key="score-' + id + '"]').each(function () {
                    let cutline = $(this).attr('cutline')
                    let val = $(this).val();
                    data.push({ cutline: cutline, discount: val })
                })
            }

            $.ajax({
                url: '/admin/user/user_discount/save/?type=' + type,
                type: 'post',
                dataType: "json",
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    alert(res.message);
                    console.log(res.message);
                    $('#btnSearch').click()
                    //getData(currentPage, 10, '<%=today%>', false);
                }

            })
        }

        function save_agent_limit(key) {
            var $ = layui.jquery;
            let data = []

            $('input[key="score-' + key + '"]').each(function () {
                let cutline = $(this).attr('cutline')
                let val = $(this).val();
                let obj = {}
                obj.cutline = cutline;
                obj[key] = val
                data.push(obj)
            })

            $.ajax({
                url: '/admin/user/user_discount/save/?type=' + key,
                type: 'post',
                dataType: "json",
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    alert(res.message);
                    console.log(res.message);
                    $('#btnSearch').click()
                }

            })
        }

