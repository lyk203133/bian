        function changeStatus(id, status) {
            let msg = status == 1 ? '确认关闭?' : '确认打开?'
            if (!confirm(msg)) return false;
            var $ = layui.jquery;
            console.log(id, status)
            let data = {
                id: id,
                status: (status == 1 ? 0 : 1)
            }
            $.ajax({
                url: '/admin/fbd/status/' + data.status,
                type: 'post',
                dataType: "json",
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    alert(res.message);
                    console.log(res.message);
                    $('#btnSearch').click()
                    //getData(currentPage, 10, '<%=today%>', false);
                }

            })
        }


