<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>layui</title>
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <link rel="stylesheet" href="/public/lib/layui-v2.6.3/css/layui.css" media="all">
    <link rel="stylesheet" href="/public/css/public.css" media="all">
</head>

<body>
    <div class="layuimini-container">
        <div class="layuimini-main">

            <!--blockquote class="layui-elem-quote layui-text">
           会员资料 
        </blockquote-->

            <fieldset class="layui-elem-field layui-field-title" style="margin-top: 20px;">
                <legend>赛事管理</legend>
            </fieldset>

            <form class="layui-form" action="/admin/user/save">
                <div class="layui-form-item">
                    <label class="layui-form-label">联赛名称</label>
                    <div class="layui-input-block">


                        <select id="leagueId" name="leagueId" lay-search lay-filter="league">
                            <option value=""></option>
                            <%for(let i in leagues) {%>
                                <option value="<%=leagues[i].id%>" <%=(fbddata && fbddata.leagueid==leagues[i].id)
                                    ? 'selected' :'' %>
                                    ><%=leagues[i].name_cn%>|<%=leagues[i].name_tw%>|<%=leagues[i].name_en%>|
                                                <%=leagues[i].name_vn%>
                                </option>
                                <%}%>
                        </select>
                        <input type="text" id="league" name="league" lay-verify="title" autocomplete="off"
                            lay-reqtext="请输入联赛名称？" placeholder="请输入联赛名称" class="layui-input"
                            value="<%=id>0?fbddata.league:''%>">
                    </div>
                </div>
                <div class="layui-form-item">
                    <label class="layui-form-label">主队</label>
                    <div class="layui-input-block">
                        <select id="homeId" name="homeId" lay-search lay-filter="hometeam">
                            <option value=""></option>
                            <%for(let i in teams) {%>
                                <option value="<%=teams[i].id%>" <%=(fbddata && fbddata.homeid==teams[i].id)
                                    ? 'selected' :'' %>
                                    ><%=teams[i].name_cn.trim()%>|<%=teams[i].name_tw%>|<%=teams[i].name_en%>|
                                                <%=teams[i].name_vn%>
                                </option>
                                <%}%>
                        </select>
                        <input type="text" id="hometeam" name="hometeam" placeholder="请输入主队" autocomplete="off"
                            class="layui-input" value="<%=id>0?fbddata.hometeam:''%>">
                    </div>
                </div>
                <div class="layui-form-item">
                    <label class="layui-form-label">客队</label>
                    <div class="layui-input-block">
                        <select id="awayId" name="awayId" lay-search lay-filter="awayteam">
                            <option value=""></option>
                            <%for(let i in teams) {%>
                                <option value="<%=teams[i].id%>" <%=(fbddata && fbddata.awayid==teams[i].id)
                                    ? 'selected' :'' %>
                                    ><%=teams[i].name_cn%>|<%=teams[i].name_tw%>|<%=teams[i].name_en%>|
                                                <%=teams[i].name_vn%>
                                </option>
                                <%}%>
                        </select>
                        <input type="text" id="awayteam" name="awayteam" placeholder="请输入客队" autocomplete="off"
                            class="layui-input" value="<%=id>0?fbddata.awayteam:''%>">
                    </div>
                </div>

                <div class="layui-form-item">
                    <label class="layui-form-label">开赛时间</label>
                    <div class="layui-input-block">
                        <input type="text" name="fbddate" id="fbddate" lay-verify="title" autocomplete="off"
                            class="layui-input" value="<%=id>0?fbddata.fbdtime:''%>" placeholder="yyyy-MM-dd HH:mm:ss">
                    </div>
                </div>

                <div class="layui-form-item">
                    <div class="layui-inline">
                        <label class="layui-form-label">全场比分赔率</label>
                        <div class="layui-input-inline">

                            <table class="layui-table" id="wholeSetting">

                                <tbody>
                                    <tr>
                                        <td>盘口
                                        </td>
                                        <% for(let i=0; i < cutlines.length; i++) { %>
                                            <td>
                                                <%= cutlines[i] %>
                                            </td>
                                            <% } %>
                                    </tr>
                                    <tr>
                                        <td style="text-align:center;line-heigth:30px">反波胆赔率</td>

                                        <% for(let i=0; i < all_data.length; i++) { %>
                                            <td>
                                                <input type="text" key="score-0" cutline="<%= all_data[i].cutline %>"
                                                    name="<%= all_data[i].cutline %>[]"
                                                    value="<%= all_data[i].fbdrate %>" style="width:50px;height:30px">

                                            </td>
                                            <% } %>

                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="layui-form-item">
                    <div class="layui-inline">
                        <label class="layui-form-label">上半场比分赔率</label>
                        <div class="layui-input-inline">

                            <table class="layui-table" id="wholeSetting">

                                <tbody>
                                    <tr>
                                        <td>盘口
                                        </td>
                                        <% for(let i=0; i < half_data.length; i++) { %>
                                            <td>
                                                <%= half_data[i].cutline %>
                                            </td>
                                            <% } %>
                                    </tr>
                                    <tr>
                                        <td style="text-align:center;line-heigth:30px">反波胆赔率 </td>

                                        <% for(let i=0; i < half_data.length; i++) { %>
                                            <td>
                                                <input type="text" key="score-0" cutline="<%= half_data[i].cutline %>"
                                                    name="<%= half_data[i].cutline %>[]"
                                                    value="<%= half_data[i].fbdrate %>" style="width:50px;height:30px">

                                            </td>
                                            <% } %>

                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>



                <div class="layui-form-item">
                    <div class="layui-input-block">
                        <button class="layui-btn" lay-submit="" lay-filter="demo1">立即提交</button>
                        <button type="reset" class="layui-btn layui-btn-primary">重置</button>
                        <input type="hidden" name="id" value="<%=id%>" />
                    </div>
                </div>
            </form>

        </div>
    </div>

    <script src="/public/lib/layui-v2.6.3/layui.js" charset="utf-8"></script>
    <script src="/public/lib/jquery-3.4.1/jquery-3.4.1.min.js" charset="utf-8"></script>
    <!-- 注意：如果你直接复制所有代码到本地，上述js路径需要改成你本地的 -->
    <script>
        layui.use(['form', 'layedit', 'laydate', 'dropdown'], function () {
            var form = layui.form
                , layer = layui.layer
                , layedit = layui.layedit
                , dropdown = layui.dropdown
                , laydate = layui.laydate;

            form.render('select', { searchCaseInsensitive: false });

            //日期
            laydate.render({
                elem: '#fbddate',
                value: '<%=today%>',
                type: 'datetime'
            });



            form.on('select(league)', function (data) {
                var selectedText = $(data.elem).find('option:selected').text();
                $('#league').val(selectedText.split('|')[0])
                console.log(selectedText)
                console.log(data.value); // 得到被选中的值
                console.log(data.othis); // 得到美化后的DOM对象
            });
            form.on('select(hometeam)', function (data) {
                var selectedText = $(data.elem).find('option:selected').text();
                $('#hometeam').val(selectedText.split('|')[0])
                console.log(selectedText)
                console.log(data.value); // 得到被选中的值
                console.log(data.othis); // 得到美化后的DOM对象
            });
            form.on('select(awayteam)', function (data) {
                var selectedText = $(data.elem).find('option:selected').text();
                $('#awayteam').val(selectedText.split('|')[0])
                console.log(selectedText)
                console.log(data.value); // 得到被选中的值
                console.log(data.othis); // 得到美化后的DOM对象
            });
            /*autocomplete.render({
                elem: '#leagueId',
                url: '/admin/league/select',
                //searchVal: '1',
                select: function (data) {
                    console.log(data.value); // 得到被选中的值
                    console.log(data.elem); // 得到当前的输入框DOM对象
                }
            });*/

            //创建一个编辑器
            var editIndex = layedit.build('LAY_demo_editor');

            //自定义验证规则
            form.verify({
                pass: [
                    /^[\S]{6,12}$/
                    , '密码必须6到12位，且不能出现空格'
                ]
                , content: function (value) {
                    layedit.sync(editIndex);
                }
            });

            //监听指定开关
            form.on('switch(switchTest)', function (data) {
                layer.msg('开关checked：' + (this.checked ? 'true' : 'false'), {
                    offset: '6px'
                });
                layer.tips('温馨提示：请注意开关状态的文字可以随意定义，而不仅仅是ON|OFF', data.othis)
            });

            //监听提交
            form.on('submit(demo1)', function (data) {

                $.ajax({
                    url: '/admin/fbddata/save',
                    type: 'post',
                    data: data.field,
                    success: function (res) {
                        console.log(res)

                        layer.alert(res.message, {
                            title: '最终的提交信息'
                        })
                        let subwin = '<%=subwin%>'
                        console.log('subwin', subwin)
                        if (res.code === 0) {
                            if (subwin == '0')
                                window.location = '/admin/user/user_rate/okrate?self=' + (res.data.agentId > 0 ? 1 : 0)
                            else {
                                var index = parent.layer.getFrameIndex(window.name);
                                parent.layui.table.reload('currentTableId');//重載父頁表格，參數為表格ID
                                parent.layer.close(index);
                                layer.close()
                            }
                        }

                    }
                })
                return false;
            });

            //表单初始赋值
            form.val('example', {
                "username": "贤心" // "name": "value"
                , "password": "123456"
                , "interest": 1
                , "like[write]": true //复选框选中状态
                , "close": true //开关状态
                , "sex": "女"
                , "desc": "我爱 layui"
            })


        });

    </script>

</body>

</html>